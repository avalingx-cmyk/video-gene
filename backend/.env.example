# Application
DEBUG=false
PROJECT_NAME="Video Generator"

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/videogene

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# External APIs
REPLICATE_API_TOKEN=
ELEVENLABS_API_KEY=
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_SECRET=

# Storage (S3/R2)
S3_ENDPOINT_URL=
S3_BUCKET=videogene
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=10
